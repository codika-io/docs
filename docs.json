{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Codika Documentation",
  "colors": {
    "primary": "#1E1432",
    "light": "#A78BFA",
    "dark": "#150E24"
  },
  "fonts": {
    "heading": {
      "family": "Satoshi",
      "weight": 700,
      "source": "https://cdn.fontshare.com/wf/BNPRT3ODDLFBWCXYJT3DHQD5HQ6KXIUF/TQZKMSQ7LSXFQXBNSJKXWQR3KMBNHYXW/SATOSHI-BOLD.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Geist"
    }
  },
  "background": {
    "color": {
      "light": "#FDFCFB",
      "dark": "#0A0F1E"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://codika.io"
  },
  "appearance": {
    "default": "system"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/use-cases",
              "concepts/processes",
              "concepts/workflows",
              "concepts/placeholders",
              "concepts/triggers",
              "concepts/credentials",
              "concepts/schemas"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/first-use-case",
              "guides/ai-workflows",
              "guides/sub-workflows",
              "guides/deployment-parameters",
              "guides/file-uploads"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/overview",
              "examples/simple-search",
              "examples/email-automation",
              "examples/scheduled-report",
              "examples/complex-rag"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["cli/overview"]
          },
          {
            "group": "Commands",
            "pages": [
              "cli/login",
              "cli/init",
              "cli/verify",
              "cli/deploy",
              "cli/trigger",
              "cli/get",
              "cli/project",
              "cli/status"
            ]
          }
        ]
      },
      {
        "tab": "Agent Skills",
        "groups": [
          {
            "group": "Overview",
            "pages": ["skills/overview"]
          },
          {
            "group": "Skills",
            "pages": [
              "skills/setup-codika",
              "skills/create-project",
              "skills/init-use-case",
              "skills/verify-use-case",
              "skills/deploy-use-case",
              "skills/fetch-use-case",
              "skills/trigger-workflow",
              "skills/get-execution"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/codika-io",
          "icon": "github"
        },
        {
          "anchor": "Platform",
          "href": "https://app.codika.io",
          "icon": "rocket"
        },
        {
          "anchor": "Website",
          "href": "https://codika.io",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:team@codika.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.codika.io"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor", "mcp"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/codika-io",
      "linkedin": "https://linkedin.com/company/codika"
    }
  }
}
